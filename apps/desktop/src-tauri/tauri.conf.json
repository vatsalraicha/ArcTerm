{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ArcTerm",
  "version": "0.1.0",
  "identifier": "dev.arcterm.desktop",
  "build": {
    "beforeDevCommand": "pnpm vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ArcTerm",
        "width": 1100,
        "height": 720,
        "minWidth": 640,
        "minHeight": 360,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#1a1a2e"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns"
    ],
    "category": "DeveloperTool",
    "shortDescription": "AI-powered modern terminal",
    "longDescription": "ArcTerm is an open-source modern terminal with Claude-powered AI features."
  },
  "plugins": {}
}
